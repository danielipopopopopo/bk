rules_version = '2';

// ============================================================================
// firestore.rules
//
// Policy:
//  - /tracks and /karts are shared reference/aggregate data: open read,
//    NO client write. Aggregate fields (globalAverageMs, uniqueDriversCount,
//    styleProfile) must only ever be recomputed by trusted server logic
//    (Cloud Function / Admin SDK) that can see across ALL users' sessions —
//    a single client can never know the true uniqueDriversCount, so it must
//    never be allowed to write it. This mirrors the app's anti-guessing
//    rule at the infrastructure level.
//  - /users/{userId} and its /sessions subcollection are strictly private:
//    only the authenticated owner may read or write their own data.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /tracks/{trackId} {
      allow read: if true;
      allow write: if false;
    }

    match /karts/{kartDocId} {
      allow read: if true;
      allow write: if false; // recomputed server-side only, see note above
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
