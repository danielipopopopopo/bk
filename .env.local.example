# ============================================================================
# .env.local.example
# Copy this file to .env.local and fill in every value. lib/firebase.ts
# throws on startup if any Firebase key is missing — no silent fallback.
# ============================================================================

# --- Firebase (client-safe; NEXT_PUBLIC_ prefix is required for browser access) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- OpenWeatherMap — SERVER-SIDE ONLY ---
# Deliberately NOT prefixed with NEXT_PUBLIC_. Consumed only inside
# app/api/weather/route.ts (runs on the server). See README.md, section
# "Deviation: weather key handling" for why this differs from the spec's
# literal client-side fetch pattern.
OPENWEATHERMAP_API_KEY=
